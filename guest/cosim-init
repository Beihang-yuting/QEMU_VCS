#!/bin/sh
# cosim-init — CoSim 专用 initramfs init 脚本
# 替换默认 init，适配 VCS RTL 仿真的高延迟环境（支持 Ubuntu/Debian）
# 主动加载所有模块 + 自适应等待 root 设备（最长 15 分钟）

export PATH=/bin:/sbin:/usr/bin:/usr/sbin

# ---- 安装 busybox applets（initramfs 可能只有精简的 symlink）----
if [ -x /bin/busybox ]; then
    /bin/busybox --install -s /bin 2>/dev/null
    /bin/busybox --install -s /sbin 2>/dev/null
fi

TIMEOUT=900  # 15 分钟

# ---- 挂载基础文件系统 ----
mkdir -p /proc /sys /dev /sysroot
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# ---- 解析 kernel cmdline ----
ROOT=""
INIT="/sbin/init"
for param in $(cat /proc/cmdline); do
    case "$param" in
        root=*)     ROOT="${param#root=}" ;;
        init=*)     INIT="${param#init=}" ;;
    esac
done

if [ -z "$ROOT" ]; then
    echo "[cosim-init] ERROR: no root= parameter in kernel cmdline"
    echo "  cmdline: $(cat /proc/cmdline)"
    echo "Dropping to shell..."
    exec /bin/sh
fi

echo "[cosim-init] Booting... (root=$ROOT)"

# ---- 主动加载所有可用模块 ----
# 不依赖 uevent/mdev/nlplug-findfs，直接遍历模块目录
KVER=$(uname -r)
MODDIR="/lib/modules/$KVER"
if [ -d "$MODDIR" ]; then
    # 静默加载模块

    # 辅助函数：尝试 modprobe，失败则 insmod（适配空 modules.dep 场景）
    try_load() {
        local mod_path="$1"
        local name=$(basename "$mod_path" | sed 's/\.ko.*$//')
        modprobe "$name" 2>/dev/null || insmod "$mod_path" 2>/dev/null || true
    }

    # 精确依赖顺序加载关键模块（insmod 不解析 modules.dep）
    # virtio 链: virtio -> virtio_ring -> virtio_pci_modern_dev -> virtio_pci_legacy_dev -> virtio_pci
    # vfio 链:   vfio -> vfio_iommu_type1 -> vfio_pci_core -> vfio_pci -> mdev
    ORDERED_MODULES="
        virtio
        virtio_ring
        virtio_pci_modern_dev
        virtio_pci_legacy_dev
        virtio_pci
        virtio_blk
        virtio_net
        pci-stub
        crc16
        crc32c_generic
        libcrc32c
        mbcache
        jbd2
        ext4
        irqbypass
        vfio
        vfio_iommu_type1
        vfio-pci-core
        vfio-pci
        mdev
    "
    for name in $ORDERED_MODULES; do
        mod_path=$(find "$MODDIR" -name "${name}.ko*" 2>/dev/null | head -1)
        if [ -n "$mod_path" ]; then
            try_load "$mod_path"
        fi
    done

    # 加载剩余模块（其他子目录中的非关键模块）
    for subdir in \
        kernel/drivers/ata \
        kernel/drivers/scsi \
        kernel/drivers/nvme \
        kernel/fs; do
        dir="$MODDIR/$subdir"
        if [ -d "$dir" ]; then
            find "$dir" -maxdepth 1 -name '*.ko*' | while read mod; do
                try_load "$mod"
            done
        fi
    done

    # 报告已加载的模块
    LOADED=$(lsmod 2>/dev/null | tail -n +2 | wc -l)
    echo "[cosim-init] Loaded $LOADED modules"
else
    echo "[cosim-init] WARNING: $MODDIR not found, no modules to load"
fi

# ---- 自适应等待 root 设备 ----
:  # 静默等待 root 设备
ELAPSED=0
while [ ! -b "$ROOT" ] && [ $ELAPSED -lt $TIMEOUT ]; do
    sleep 1
    ELAPSED=$((ELAPSED + 1))
    # 每 30 秒打印一次进度
    if [ $((ELAPSED % 30)) -eq 0 ]; then
        echo "[cosim-init] Still waiting for $ROOT... (${ELAPSED}s elapsed)"
        # 列出已发现的块设备
        BLKDEVS=$(ls /dev/vd* /dev/sd* /dev/nvme* /dev/xvd* 2>/dev/null | tr '\n' ' ')
        if [ -n "$BLKDEVS" ]; then
            echo "[cosim-init]   Found block devices: $BLKDEVS"
        fi
    fi
done

if [ ! -b "$ROOT" ]; then
    echo "[cosim-init] ERROR: root device $ROOT not found after ${TIMEOUT}s"
    echo "[cosim-init] Available block devices:"
    ls -la /dev/vd* /dev/sd* /dev/nvme* /dev/xvd* 2>/dev/null || echo "  (none)"
    echo "[cosim-init] Loaded modules:"
    lsmod 2>/dev/null || echo "  (lsmod not available)"
    echo ""
    echo "Dropping to emergency shell. Debug hints:"
    echo "  cat /proc/cmdline"
    echo "  ls /dev/"
    echo "  lsmod"
    echo "  dmesg | grep -i virtio"
    exec /bin/sh
fi

:  # root 设备已找到

# ---- 挂载 root + switch_root ----
mkdir -p /sysroot
if ! mount -t auto "$ROOT" /sysroot; then
    echo "[cosim-init] ERROR: failed to mount $ROOT"
    exec /bin/sh
fi

:  # 挂载成功，切换到真实 root

# ---- 安装 cosim 驱动到真实 root（从 initramfs 复制）----
if [ -f /lib/modules/cosim_nic.ko ]; then
    mkdir -p /sysroot/lib/modules
    cp /lib/modules/cosim_nic.ko /sysroot/lib/modules/ 2>/dev/null
    echo "[cosim-init] Installed cosim_nic.ko to rootfs"
fi
if [ -f /etc/cosim/driver.conf ]; then
    mkdir -p /sysroot/etc/cosim
    cp /etc/cosim/driver.conf /sysroot/etc/cosim/ 2>/dev/null
fi
if [ -f /etc/local.d/cosim-driver.start ]; then
    mkdir -p /sysroot/etc/local.d
    cp /etc/local.d/cosim-driver.start /sysroot/etc/local.d/ 2>/dev/null
    chmod +x /sysroot/etc/local.d/cosim-driver.start 2>/dev/null
fi

# 自动探测 init 路径（Ubuntu/Debian=/lib/systemd/systemd 或 /sbin/init）
if [ ! -e "/sysroot${INIT}" ]; then
    for candidate in /sbin/init /lib/systemd/systemd /bin/init /usr/lib/systemd/systemd; do
        if [ -x "/sysroot${candidate}" ]; then
            INIT="$candidate"
            break
        fi
    done
fi

# 将 proc/sys/dev 移动到新 root（switch_root 需要）
mount --move /proc /sysroot/proc 2>/dev/null
mount --move /sys /sysroot/sys 2>/dev/null
mount --move /dev /sysroot/dev 2>/dev/null

exec switch_root /sysroot "$INIT"
