# ============================================================
# CoSim Platform 环境配置
# 用法：修改此文件适配目标机环境，然后运行 setup.sh
# ============================================================

# ---- VCS (Synopsys) 路径 ----
# VCS 安装根目录（setup.sh 自动查找 vcs 二进制）
# 如果 vcs 已在 PATH 中，留空即可
VCS_HOME=""
SNPSLMD_LICENSE_FILE="/opt/synopsys/license/license.dat"
LM_LICENSE_FILE="/opt/synopsys/license/license.dat"

# ---- QEMU 构建选项 ----
QEMU_VERSION="v9.2.0"
# 如果目标机无法访问 GitHub，可以手动放置源码到 third_party/qemu/
# setup.sh 会跳过下载

# ---- Guest 网络配置 ----
# 双 VCS 模式
GUEST1_IP="10.0.0.1"
GUEST2_IP="10.0.0.2"
GUEST1_MAC="de:ad:be:ef:00:01"
GUEST2_MAC="de:ad:be:ef:00:02"

# TAP 模式
TAP_IP="10.0.0.1"
TAP_MAC="de:ad:be:ef:00:02"
GUEST_IP="10.0.0.2"
GUEST_MAC="de:ad:be:ef:00:01"

# ---- Guest 内存 ----
GUEST_MEMORY="256M"

# ---- 超时设置（秒）----
PHASE5_TIMEOUT=300
TAP_TIMEOUT=120

# ---- Guest 镜像路径（留空则自动搜索 guest/images/）----
KERNEL_PATH=""
ROOTFS_PATH=""

# ---- Initramfs 额外工具 ----
# 如果需要 iperf3/nc 测试，设为 1
INCLUDE_IPERF3=1
INCLUDE_NETCAT=1
